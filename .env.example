DEEPSEEK_API_KEY=sk-ffe33cecdb9e4d2b978c44f4eb879388
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
TEMPERATURE=0.3
MAX_TOKENS=4096
REQUEST_TIMEOUT=60
MAX_RETRIES=3

# ===== 功能开关 =====
# 自洽性验证开关 (true/false)
ENABLE_SELF_CONSISTENCY=false
# 多模型集成开关 (true/false)
ENABLE_MULTI_MODEL=false
# 多Agent辩论开关 (true/false)
ENABLE_MULTI_AGENT_DEBATE=false
# 推理链条开关 (true/false)
ENABLE_REASONING_CHAIN=false

# ===== 自洽性验证配置 =====
# 采样次数
SELF_CONSISTENCY_SAMPLES=3
# 最低温度
SELF_CONSISTENCY_TEMPERATURE_MIN=0.1
# 最高温度
SELF_CONSISTENCY_TEMPERATURE_MAX=0.5
# 置信度阈值（低于此值标记为高不确定性）
CONFIDENCE_THRESHOLD=60

# ===== 多模型集成配置 =====
# 多模型列表，JSON格式，为空时使用默认配置
# 示例: [{"name": "model1", "api_key": "...", "base_url": "...", "model": "...", "weight": 0.5}, ...]
MULTI_MODEL_LIST=[]
# 集成策略: weighted_vote, majority_vote, average
MULTI_MODEL_STRATEGY=weighted_vote

# ===== 多Agent辩论配置 =====
# 辩论轮次
DEBATE_ROUNDS=2
# 参与辩论的Agent角色，JSON格式数组
DEBATE_AGENTS=["tech_expert", "industry_analyst", "risk_assessor"]

# ===== 路线图增强配置 =====
# 增强路线图解析开关 (true/false)
ENABLE_ROADMAP_ENHANCED=false

# ===== 回溯验证配置 =====
# 回溯历史年份
BACKTEST_HISTORICAL_YEAR=2020